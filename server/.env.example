# Copie para .env (na pasta server/) e ajuste.
# Em produção (Railway), defina como Environment Variables no painel.

# Node
NODE_ENV=development
PORT=4000

# Postgres — em dev, usa o do docker-compose na raiz do projeto
DATABASE_URL=postgres://postgres:postgres@localhost:5432/taskflow

# CORS — origem do frontend Vite em dev
FRONTEND_ORIGIN=http://localhost:5173

# Auth
# Gere um segredo forte: `openssl rand -base64 32` (ou qualquer string >=16 chars).
JWT_SECRET=troque-este-segredo-em-producao-32-chars-min
JWT_EXPIRES_IN=7d
BCRYPT_ROUNDS=10

# Storage
# - disk: salva uploads em STORAGE_DISK_DIR (dev, simples).
# - s3:   usa S3-compatível (Cloudflare R2, AWS S3, Backblaze B2…).
STORAGE_DRIVER=disk
STORAGE_DISK_DIR=./uploads

# Quando STORAGE_DRIVER=s3, preencha tudo abaixo:
# Exemplo R2: https://<account_id>.r2.cloudflarestorage.com
# S3_ENDPOINT=
# S3_REGION=auto
# S3_BUCKET=
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# Base pública dos arquivos (R2 expõe via *.r2.dev ou domínio customizado)
# STORAGE_PUBLIC_URL=https://pub-xxxxxxx.r2.dev
