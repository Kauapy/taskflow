{
  "name": "taskflow-server",
  "version": "0.1.0",
  "private": true,
  "type": "commonjs",
  "description": "Backend Node + Express + Postgres do Taskflow (substitui Supabase)",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "migrate": "tsx src/migrate.ts",
    "smoke": "tsx src/smoke-auth.ts",
    "smoke:tasks": "tsx src/smoke-tasks.ts",
    "smoke:shares": "tsx src/smoke-shares.ts",
    "smoke:uploads": "tsx src/smoke-uploads.ts",
    "smoke:security": "tsx src/smoke-security.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1057.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "pg": "^8.12.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.14.0",
    "@types/pg": "^8.11.6",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3"
  }
}
