# Copie este arquivo para .env (na raiz do projeto) e preencha com seus valores.
# Os valores estão no painel do Supabase: Project Settings → API.
# Nunca comite o arquivo .env com valores reais — ele já está no .gitignore.

VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key-here
